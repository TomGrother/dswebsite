# Internal SQL Server -> Order Hub sync — copy to sync/.env and fill in.
# This file runs on the internal Design & Supply network, NOT on Railway.

# --- Internal SQL Server (read-only access is enough) ---
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_DB=YourInternalDbName
SQLSERVER_USER=order_hub_reader
SQLSERVER_PASSWORD=change-me
SQLSERVER_ENCRYPT=false

# --- Where to push, and the shared secret (must match the hub's INGEST_API_KEY) ---
HUB_INGEST_URL=https://designandsupply.co.uk/api/ingest/doors
INGEST_API_KEY=change-me-to-a-long-random-string

# Retention (must match the hub). Once EVERY door on an order is packed, the
# whole order stays visible for RECENT_DAYS after the last door was actually
# packed (dbo.door.date_pack_complete), then drops as a unit. Un-packed doors
# drop once scheduled more than STALE_DAYS ago (kills ancient un-packed orders).
RECENT_DAYS=14
STALE_DAYS=90
