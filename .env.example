# ============================================================
# Design & Supply — website + Order Hub (single Express app)
# Copy to .env for local dev; set the same keys in Railway for production.
# Never commit real secrets.
# ============================================================

# --- Core ---
PORT=3000
# Persistent data dir. On Railway, point this at a mounted Volume (e.g. /data)
# or the SQLite databases (content.db, orders.db) are wiped on every deploy.
DATA_DIR=./data

# --- Marketing site CMS admin (News / Case Studies) ---
ADMIN_PASSWORD=change-me

# --- Internal pricing shop (unlinked). Optional password gate. ---
# SHOP_PASSWORD=change-me

# ============================================================
# Order Hub
# ============================================================
# Signs the portal session cookie. REQUIRED for portal logins in production.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Shared secret for the internal sync -> /api/ingest/doors. Must match sync/.env.
INGEST_API_KEY=change-me-to-a-long-random-string

# Recency window (days). A door shows if it isn't packed yet, or its scheduled
# completion is within this many days. Must match sync/.env RECENT_DAYS.
RECENT_DAYS=30

# First staff admin, created automatically on boot if it doesn't exist yet.
PORTAL_ADMIN_EMAIL=admin@designandsupply.co.uk
PORTAL_ADMIN_PASSWORD=change-me
