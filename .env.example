# ============================================================
# Design & Supply — website + Order Hub (single Express app)
# Copy to .env for local dev; set the same keys in Railway for production.
# Never commit real secrets.
# ============================================================

# --- Core ---
PORT=3000
# Persistent data dir. On Railway, point this at a mounted Volume (e.g. /data)
# or the SQLite databases (content.db, orders.db) are wiped on every deploy.
DATA_DIR=./data

# --- Marketing site CMS admin (News / Case Studies) ---
ADMIN_PASSWORD=change-me

# --- Internal pricing shop (unlinked). Optional password gate. ---
# SHOP_PASSWORD=change-me

# ============================================================
# Order Hub
# ============================================================
# Signs the portal session cookie. REQUIRED for portal logins in production.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-string

# Shared secret for the internal sync -> /api/ingest/doors. Must match sync/.env.
INGEST_API_KEY=change-me-to-a-long-random-string

# Recency window (days). Packed doors stay visible for RECENT_DAYS after their
# scheduled date; un-packed doors drop once scheduled more than STALE_DAYS ago
# (drops ancient un-packed orders). Must match sync/.env.
RECENT_DAYS=30
STALE_DAYS=90

# First staff admin, created automatically on boot if it doesn't exist yet.
PORTAL_ADMIN_EMAIL=admin@designandsupply.co.uk
PORTAL_ADMIN_PASSWORD=change-me

# --- Customer emails (Resend) ---
# Powers the daily order digest AND self-service password resets. Leave
# RESEND_API_KEY unset to disable both (password reset links are then logged to
# the server console instead of emailed). Sending domain (designandsupply.co.uk)
# must be verified in Resend.
RESEND_API_KEY=
# Sender shown on the email.
NOTIFY_FROM=Design & Supply <notifications@designandsupply.co.uk>
# Earliest UK hour (0-23) to send the daily summary.
DIGEST_HOUR=7
# Link used in the email to reach the portal.
PORTAL_URL=https://designandsupply.co.uk/portal
